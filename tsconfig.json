{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": ".",
        "rootDir": ".",
        "moduleResolution": "bundler"
    },
    "include": ["main.ts"],
    "exclude": ["node_modules"]
}
